# KuCoin Lane - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === KUCOIN API (REQUIRED FOR LIVE/PAPER) ===
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

# === TRADING ===
ACCOUNT_BALANCE=10000
PAPER_TRADING=true
TRADING_PAIRS=SOL/USDT,BTC/USDT,ETH/USDT
MAX_OPEN_POSITIONS=1

# === RISK ===
RISK_PER_TRADE=0.005
MIN_RISK_REWARD_RATIO=1.5
MAX_DAILY_LOSS=0.05
MIN_SIGNAL_STRENGTH=0.25
MIN_NOTIONAL_USD=10.0
DEFAULT_STOP_LOSS_PCT=0.02
MAX_POSITION_SIZE_USD=10.0

# === POSITION SIZING ===
MIN_SIZE_SOL=0.01
MIN_SIZE_BTC=0.0001
MIN_SIZE_ETH=0.001

# === ASSET PROFILES ===
# Optional path to JSON profile file with risk/market/backtest pair overrides.
ASSET_CONFIGS_PATH=./config/asset_profiles.json
# Optional inline JSON override (takes precedence if set).
# ASSET_CONFIGS_JSON={"risk":{"pairs":{"XRP/USDT":{"position_size_multiplier":0.7}}}}

# === MARKET ANALYSIS ===
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
DOWNTREND_THRESHOLD=-5

# === BACKTEST ===
BACKTEST_MIN_WIN_RATE=0.45
BACKTEST_MAX_DRAWDOWN=0.15

# === DATA ===
CACHE_TIMEOUT=300
API_TIMEOUT=10

# === ENTRY TIMING ===
ENTRY_TIMING_ENABLED=true
REVERSAL_THRESHOLD_PCT=0.001

# === REGIME GUARD ===
REGIME_GUARD_MODE=v1_soft_halt

# === TELEGRAM (OPTIONAL) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === MONITORING ===
LOGS_DIR=./logs
ENABLE_ALERTS=true
ALERT_LEVEL=WARNING

# === MODE ===
MODE=PAPER
