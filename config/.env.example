# KuCoin Lane - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === KUCOIN API (REQUIRED FOR LIVE/PAPER) ===
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

# === TRADING ($110 USDT / $150 CAD micro-trading defaults) ===
ACCOUNT_BALANCE=110
PAPER_TRADING=true
TRADING_PAIRS=BTC/USDT,ETH/USDT
MAX_OPEN_POSITIONS=2

# === RISK ===
RISK_PER_TRADE=0.01
MIN_RISK_REWARD_RATIO=1.2
MAX_DAILY_LOSS=0.03
MIN_SIGNAL_STRENGTH=0.30
MIN_NOTIONAL_USD=5.0
DEFAULT_STOP_LOSS_PCT=0.02
MAX_POSITION_SIZE_USD=55.0

# === POSITION SIZING ===
MIN_SIZE_BTC=0.00001
MIN_SIZE_ETH=0.0001
# MIN_SIZE_AVAX=0.01
# MIN_SIZE_DOGE=1.0
# MIN_SIZE_LINK=0.1

# === ASSET PROFILES ===
ASSET_CONFIGS_PATH=./config/asset_profiles.json
# ASSET_CONFIGS_JSON={"risk":{"pairs":{"XRP/USDT":{"position_size_multiplier":0.7}}}}

# === MARKET ANALYSIS ===
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
DOWNTREND_THRESHOLD=-5

# === BACKTEST ===
BACKTEST_MIN_WIN_RATE=0.45
BACKTEST_MAX_DRAWDOWN=0.15

# === DATA ===
CACHE_TIMEOUT=300
API_TIMEOUT=10

# === ENTRY TIMING ===
ENTRY_TIMING_ENABLED=true
REVERSAL_THRESHOLD_PCT=0.001

# === REGIME GUARD ===
REGIME_GUARD_MODE=v1_soft_halt

# === TELEGRAM (OPTIONAL) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === MONITORING ===
LOGS_DIR=./logs
ENABLE_ALERTS=true
ALERT_LEVEL=WARNING

# === SOLANA RPC (FOR CREATOR TRACKER) ===
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# === MODE ===
MODE=PAPER
# Spot long-only: only open long positions; SELL signals close existing longs or skip
SPOT_LONG_ONLY=true
